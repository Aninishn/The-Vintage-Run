{
  "name": "The Vintage Run API",
  "description": "A hypothetical API for managing and retrieving information about vintage cars for 'The Vintage Run' website.",
  "base_url": "https://api.thevintagerun.com/v1",
  "endpoints": [
    {
      "path": "/cars",
      "method": "GET",
      "description": "Retrieves a list of all vintage cars.",
      "response_example": [
        {
          "id": "car-001",
          "name": "Porsche 901",
          "year": 1964,
          "engine": "2.0L Flat-6",
          "horsepower": "130 hp",
          "top_speed_kmh": 210,
          "0-100 km/h": 9.1,
          "description": "The prototype of the legendary 911. Sleek, fast, and rebellious — just like the '60s.",
          "image_url": "/img/model-car-1.jpg",
          "details_url": "/cars/car-001"
        },
        {
          "id": "car-002",
          "name": "Lamborghini Miura P400 SV",
          "year": 1971,
          "engine": "4.0L V12",
          "horsepower": "385 hp",
          "top_speed_kmh": 290,
          "0-100 km/h": 4.7,
          "image_url": "/img/model-car-2.jpg",
          "details_url": "/cars/car-002"
        },
        {
          "id": "car-003",
          "name": "Chevrolet Corvette (C2)",
          "year": 1963,
          "engine": "5.4L V8",
          "horsepower": "300 hp",
          "top_speed_kmh": 241,
          "0-100 km/h": 6.5,
          "image_url": "/img/model-car-3.jpg",
          "details_url": "/cars/car-003"
        }
      ],
      "parameters": []
    },
    {
      "path": "/cars/{id}",
      "method": "GET",
      "description": "Retrieves details for a specific vintage car by its ID.",
      "response_example": {
        "id": "car-001",
        "name": "Porsche 901",
        "year": 1964,
        "engine": "2.0L Flat-6",
        "horsepower": "130 hp",
        "top_speed_kmh": 210,
        "acceleration_0_100_s": 9.1,
        "description": "The original 901, later renamed 911, set the standard for Porsche's iconic sports car line. Known for its distinctive design and engaging driving experience.",
        "images": ["/img/model-car-1.jpg"]
      },
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "Unique identifier of the car."
        }
      ]
    },
    {
      "path": "/newsletter/subscribe",
      "method": "POST",
      "description": "Subscribes a user to the newsletter.",
      "request_body_example": {
        "name": "John Doe",
        "email": "john.doe@example.com"
      },
      "response_example": {
        "message": "Subscription successful!",
        "subscriber_id": "sub-12345"
      },
      "parameters": [
        {
          "name": "name",
          "in": "body",
          "type": "string",
          "required": true,
          "description": "Subscriber's full name."
        },
        {
          "name": "email",
          "in": "body",
          "type": "string",
          "format": "email",
          "required": true,
          "description": "Subscriber's email address."
        }
      ]
    }
  ]
}
